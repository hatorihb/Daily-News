{
  "permissions": {
    "allow": [
      "Edit(.claude/hooks/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/secret-scan.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/report-check.sh" }
        ]
      }
    ]
  }
}
